# ============================================================
# TEMPLATE - Copiar a .env en desarrollo local
# ============================================================
# NUNCA subas el archivo .env real a Git
# Este archivo es solo referencia/documentación
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# MySQL - Desarrollo local
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=portfolio_contact
DB_AUTO_MIGRATE=true
DB_SSL=false

# CORS - Dominio del frontend en desarrollo
CORS_ORIGIN=http://127.0.0.1:5500

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000
